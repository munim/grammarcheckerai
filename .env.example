# Environment variables for Grammar Correction Tool
# ----------------------------------------------------------------------------
# This app supports three LLM providers, selected server-side via
# ACTIVE_PROVIDER. Configure credentials for the ONE provider you want to use
# and uncomment it; the rest can stay commented out.
#
#   ACTIVE_PROVIDER=openrouter (default) -> OpenRouter API
#   ACTIVE_PROVIDER=nvidia             -> NVIDIA NIM (build.nvidia.com)
#   ACTIVE_PROVIDER=custom             -> Any OpenAI-compatible endpoint
# ----------------------------------------------------------------------------

# === Provider selection =====================================================
# Pick the active LLM provider. Allowed values: openrouter, nvidia, custom.
# Defaults to "openrouter" when unset (backward-compatible).
# ACTIVE_PROVIDER=openrouter

# === OpenRouter (used when ACTIVE_PROVIDER=openrouter, the default) =========
# Your OpenRouter API key. Get one (free) at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model id. Optional; defaults to mistralai/mistral-7b-instruct:free.
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# Application URL — used as the HTTP-Referer header that OpenRouter requires.
NEXTJS_URL=http://localhost:3000

# === NVIDIA NIM (used when ACTIVE_PROVIDER=nvidia) ==========================
# Uncomment and fill in to switch the server to NVIDIA NIM.
# Get your API key at https://build.nvidia.com
# NVIDIA_API_KEY=nvapi-your_key_here
#
# NIM model id. Optional; defaults to meta/llama-3.1-70b-instruct.
# Common alternatives: meta/llama-3.1-8b-instruct, mistralai/mistral-large,
# google/gemma-2-9b-it.
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct
#
# Override only for a self-hosted NIM or private endpoint.
# Optional; defaults to https://integrate.api.nvidia.com/v1.
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# === Custom OpenAI-compatible endpoint (used when ACTIVE_PROVIDER=custom) ===
# Uncomment to point at any endpoint that speaks the OpenAI Chat Completions
# schema (LM Studio, Ollama's /v1 listener, vLLM, OpenRouter proxy, etc.).
#
# Base URL of the chat-completions endpoint (trailing slashes are stripped).
# CUSTOM_BASE_URL=https://your-endpoint.example.com/v1
#
# Bearer token for the endpoint. Required when ACTIVE_PROVIDER=custom.
# CUSTOM_API_KEY=your_key_for_that_endpoint
#
# Model id to send with each request. Optional; defaults to gpt-3.5-turbo.
# CUSTOM_MODEL=gpt-3.5-turbo

# === Cloudflare Turnstile (bot protection) ==================================
# Secret key (server-side, required for production).
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Site key (client-side, required for the frontend widget in production).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Set to "false" to disable Turnstile verification entirely. Optional;
# defaults to true.
NEXT_PUBLIC_TURNSTILE_ENABLED=true

# === Docker ================================================================
# Host port (used by docker-compose). Optional; defaults to 3000.
HOST_PORT=3000
